# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

# List directory contents
alias ls='ls -hF --color=auto --group-directories-first'
alias ll='ls -lAhF --color=auto --group-directories-first'
alias tree='tree -C'

# Safety features
alias cp='cp -vi'
alias mv='mv -vi'
alias rm='rm -vi'
alias del='trash-put'

# File operations
alias cat='bat'
# Search all history
gh() { history 1 | grep "$@" }

# Development
alias py='python3'
# Activate a Python venv, preferring .venv over venv
sa() {
  if [[ -f .venv/bin/activate ]]; then
    source .venv/bin/activate
  elif [[ -f venv/bin/activate ]]; then
    source venv/bin/activate
  else
    echo "sa: no .venv or venv found in $PWD" >&2
    return 1
  fi
}

# Editors
alias e='emacsclient --alternate-editor=""'
alias v='vim'

# System
alias cls='clear'
alias zshreload='source ~/.config/zsh/.zshrc && echo Zsh config reloaded'
#alias U='sudo apt -y update && sudo apt -y upgrade && sudo apt -y autoremove && sudo apt -y autoclean'
# U command now handled by ~/bin/U script with OS detection

alias sus='slock_off && systemctl suspend'
# Document viewers
alias z='zathura'

# Package management
#alias zyp='zypper'

# Image viewers
#alias sxiv='sxivrun'

# Custom lf
alias lf='lfrun'