#!/bin/bash

# Bluetooth MAC address of your headphones
#DEVICE_MAC="D8:D6:2C:CD:7D:17"
DEVICE_MAC="C4:90:3B:41:C6:40"

# Use bluetoothctl to check the connection status
if bluetoothctl info "$DEVICE_MAC" | grep -q "Connected: yes"; then
    echo "Device is connected. Disconnecting..."
    bluetoothctl disconnect "$DEVICE_MAC"
else
    echo "Device is disconnected. Scanning..."
    bluetoothctl --timeout 30 scan on > /dev/null &
    SCAN_PID=$!

    for i in $(seq 1 30); do
        if bluetoothctl info "$DEVICE_MAC" 2>/dev/null | grep -q "RSSI:"; then
            echo "Device found."
            break
        fi
        sleep 0.5
    done

    echo "Connecting..."
    bluetoothctl connect "$DEVICE_MAC"

    kill "$SCAN_PID" 2>/dev/null
    wait "$SCAN_PID" 2>/dev/null
fi

## Reminder, if it won't connect without scanning first:
# bluetoothctl
# power on
# agent on
# default-agent
# scan on
# pair C4:90:3B:41:C6:40
# trust C4:90:3B:41:C6:40
# connect C4:90:3B:41:C6:40
